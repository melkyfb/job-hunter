# ── Provider ──────────────────────────────────────────────────────────────────
# Options: "openai" | "local"
LLM_PROVIDER=local

# ── OpenAI (only required when LLM_PROVIDER=openai) ──────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Local / OpenAI-compatible server ─────────────────────────────────────────
# Running locally (npm run dev):
#   Ollama default:  http://localhost:11434/v1
#   LM Studio:       http://localhost:1234/v1
#
# Running via Docker (docker compose up):
#   Use host.docker.internal instead of localhost so the container can reach
#   the LLM server on the host machine. docker-compose.yml overrides this
#   automatically — you only need to change it here for local dev.
#   freellmapi: http://host.docker.internal:3001/v1
#   Ollama:     http://host.docker.internal:11434/v1
#   LM Studio:  http://host.docker.internal:1234/v1
#
# Any remote server: https://my-server.example.com/v1
LOCAL_BASE_URL=http://localhost:11434/v1
LOCAL_API_KEY=ollama
LOCAL_MODEL=llama3.2

# ── Shared LLM parameters ─────────────────────────────────────────────────────
LLM_TEMPERATURE=0.0
LLM_MAX_RETRIES=3

# ── Job Search ─────────────────────────────────────────────────────────────────
# Options: "mock" (no API key needed) | "adzuna" (free tier at developer.adzuna.com)
SEARCH_PROVIDER=mock
ADZUNA_APP_ID=
ADZUNA_API_KEY=
ADZUNA_COUNTRY=de
