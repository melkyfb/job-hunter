{
  "productName": "Job Hunter Assistant",
  "version": "0.1.0",
  "identifier": "io.github.melkyfb.jobhunter",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --dir frontend dev",
    "beforeBuildCommand": "pnpm --dir frontend build"
  },
  "app": {
    "windows": [
      {
        "title": "Job Hunter Assistant",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/job-hunter-backend"]
  }
}
